<Window x:Class="ClinicManagement.UI.Views.ServicePriceHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="Quản lý giá dịch vụ" Height="600" Width="600" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="QUẢN LÝ GIÁ DỊCH VỤ" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,20"/>
        
        <TextBlock Grid.Row="1" Text="{Binding CurrentService.Name, StringFormat='Dịch vụ: {0}'}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <!-- Thiết lập giá mới -->
        <GroupBox Grid.Row="2" Header="Thiết lập giá mới" Margin="0,0,0,20" materialDesign:ColorZoneAssist.Mode="Standard">
            <StackPanel Margin="10">
                <TextBlock Text="{Binding Error}" Foreground="Red" Margin="0,0,0,10">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Error}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Error}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Giá tổng (VNĐ) *" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding NewPrice, UpdateSourceTrigger=PropertyChanged}"/>
                    <DatePicker Grid.Column="2" materialDesign:HintAssist.Hint="Ngày có hiệu lực *" SelectedDate="{Binding NewEffectiveDate, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="3" Command="{Binding SetPriceCommand}" Content="Lưu" Style="{StaticResource MaterialDesignRaisedButton}" Margin="10,0,0,0" VerticalAlignment="Bottom"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <TextBlock Grid.Row="3" Text="Lịch sử giá" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
        
        <!-- Bảng lịch sử giá -->
        <DataGrid Grid.Row="4" ItemsSource="{Binding PriceHistory}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="White" BorderThickness="1" BorderBrush="#E2E8F0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Giá" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Giá tổng (VNĐ)" Binding="{Binding Price, StringFormat='{}{0:N0}'}" Width="*"/>
                <DataGridTextColumn Header="Ngày hiệu lực" Binding="{Binding EffectiveDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="120"/>
                <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
